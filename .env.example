# Copy this file to .env and fill it in. Never commit .env.

# --- Option 1: SendGrid ---
# If this key is set, the script sends via SendGrid and ignores the SMTP block below.
# Leave empty to use SMTP instead.
SENDGRID_API_KEY=

# --- Option 2: SMTP ---
# The mailbox that sends the report.
EMAIL_USER=email@email.com

# App-specific password, NOT your account password.
# Gmail: myaccount.google.com/apppasswords (requires 2FA enabled)
# Outlook/365: account.microsoft.com/security
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Your provider's outgoing mail server and port.
# Gmail: smtp.gmail.com / 587    Outlook: smtp.office365.com / 587
SMTP_SERVER=smtp.email.com
SMTP_PORT=587

# --- Recipients ---
# Sender address shown on the email. Defaults to EMAIL_USER if left empty.
EMAIL_FROM=email@email.com

# Where the report goes. Comma or semicolon separated for multiple addresses.
EMAIL_TO=otheremail@email.com

# Optional copies. Same format. Add your own address here to receive a copy.
EMAIL_CC=
EMAIL_BCC=
